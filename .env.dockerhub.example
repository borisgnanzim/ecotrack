# Docker Hub deployment variables
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# Production secrets and shared settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecotrack_bootstrap
REDIS_PASSWORD=redis_password
JWT_SECRET=change-me
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3010

# Optional published ports
POSTGRES_PORT=5432
REDIS_PORT=6379
ZOOKEEPER_PORT=2181
KAFKA_PORT_INTERNAL=19029
KAFKA_PORT_EXTERNAL=19092
KAFKA_UI_PORT=8080
REDIS_COMMANDER_PORT=8081