# ============================================
# Infrastructure Locale (Docker Compose)
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://ecotrack:ecotrack_password@postgres:5432/ecotrack_db

# Redis
REDIS_URL=redis://:redis_password@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=ecotrack-service

# Notification Mode (local = base de données, http = service externe)
NOTIFICATION_MODE=local

# Node Environment
NODE_ENV=development

# Service Ports (chaque service sur un port différent)
# service-users: 3002
# service-containers: 3003
# service-routes: 3004
# service-analytics: 3005
# api-gateway: 3000
