# ============================================
# Infrastructure Locale (Docker Compose)
# ============================================

# PostgreSQL
POSTGRES_USER=ecotrack
POSTGRES_PASSWORD=ecotrack_password
POSTGRES_DB=ecotrack_db
DATABASE_URL=postgresql://ecotrack:ecotrack_password@postgres:5432/ecotrack_db

# Redis
REDIS_PASSWORD=redis_password
REDIS_URL=redis://:redis_password@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=ecotrack-service

# Notification Mode (local = base de données, http = service externe)
NOTIFICATION_MODE=local

# Node Environment
NODE_ENV=development

# Service Ports (chaque service sur un port différent)
# service-users: 3002
# service-containers: 3003
# service-routes: 3004
# service-analytics: 3005
# api-gateway: 3000

# ============================================
# Docker Compose Ports Configuration
# ============================================

# Redis port
REDIS_PORT=6379

# Zookeeper port
ZOOKEEPER_PORT=2181

# Kafka internal port (for inter-service communication)
KAFKA_PORT_INTERNAL=29092

# Kafka external port (for external access)
KAFKA_PORT_EXTERNAL=19092

# Kafka UI port
KAFKA_UI_PORT=8080

# Redis Commander port
REDIS_COMMANDER_PORT=8081

# PostgreSQL port (uncomment in docker-compose.yml if needed)
POSTGRES_PORT=5432
