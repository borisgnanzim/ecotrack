generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum AnomalyType {
  SENSOR_FAILURE
  ABNORMAL_FILL_RATE
  MISSED_COLLECTION
  ROUTE_DEVIATION
  EQUIPMENT_FAILURE
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ReportPeriod {
  DAY
  WEEK
  MONTH
  YEAR
}

enum FileFormat {
  PDF
  EXCEL
  CSV
  JSON
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  SENT
  FAILED
}

// ==================== MODÈLES ANALYTICS ====================

// Métriques agrégées par conteneur
model ContainerMetrics {
  id              String    @id @default(uuid()) @db.Uuid
  containerId     String    @db.Uuid  // Référence service-containers
  date            DateTime  @default(now()) @db.Date
  avgFillLevel    Float     @default(0)
  maxFillLevel    Int       @default(0)
  minFillLevel    Int       @default(0)
  collectionCount Int       @default(0)
  totalWeight     Float     @default(0)
  createdAt       DateTime  @default(now())

  @@unique([containerId, date])
  @@index([date])
  @@index([containerId])
  @@map("container_metrics")
}

// Métriques agrégées par zone
model ZoneMetrics {
  id              String    @id @default(uuid()) @db.Uuid
  zoneId          String
  date            DateTime  @default(now()) @db.Date
  totalContainers Int       @default(0)
  criticalCount   Int       @default(0)
  avgFillLevel    Float     @default(0)
  collectionCount Int       @default(0)
  totalWeight     Float     @default(0)
  createdAt       DateTime  @default(now())

  @@unique([zoneId, date])
  @@index([date])
  @@index([zoneId])
  @@map("zone_metrics")
}

// Métriques agrégées par agent
model AgentMetrics {
  id                  String    @id @default(uuid()) @db.Uuid
  agentId             String    @db.Uuid  // Référence service-users
  date                DateTime  @default(now()) @db.Date
  routesCompleted     Int       @default(0)
  routesPlanned       Int       @default(0)
  containersCollected Int       @default(0)
  totalDistance       Float     @default(0)
  totalTime           Int       @default(0)
  avgFillLevel        Float     @default(0)
  createdAt           DateTime  @default(now())

  @@unique([agentId, date])
  @@index([date])
  @@index([agentId])
  @@map("agent_metrics")
}

// Métriques quotidiennes globales
model DailyMetrics {
  id                  String    @id @default(uuid()) @db.Uuid
  date                DateTime  @unique @db.Date
  totalContainers     Int       @default(0)
  criticalContainers  Int       @default(0)
  totalCollections    Int       @default(0)
  totalWeight         Float     @default(0)
  activeRoutes        Int       @default(0)
  completedRoutes     Int       @default(0)
  activeAgents        Int       @default(0)
  signalements        Int       @default(0)
  avgFillLevel        Float     @default(0)
  createdAt           DateTime  @default(now())

  @@index([date])
  @@map("daily_metrics")
}

// Historique des prédictions de remplissage
model FillPrediction {
  id              String    @id @default(uuid()) @db.Uuid
  containerId     String    @db.Uuid
  predictedDate   DateTime  @db.Date
  predictedFill   Int
  actualFill      Int?
  weatherFactor   Float     @default(0)
  confidence      Float     @default(0)
  modelVersion    String    @default("v1")
  createdAt       DateTime  @default(now())

  @@unique([containerId, predictedDate])
  @@index([predictedDate])
  @@index([containerId])
  @@map("fill_predictions")
}

// Anomalies détectées
model Anomaly {
  id              String           @id @default(uuid()) @db.Uuid
  type            AnomalyType
  severity        AnomalySeverity
  containerId     String?          @db.Uuid
  sensorId        String?
  description     String
  details         Json?
  isResolved      Boolean          @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())

  @@index([type])
  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
  @@map("anomalies")
}

// Rapports générés
model Report {
  id              String         @id @default(uuid()) @db.Uuid
  type            ReportType
  period          ReportPeriod
  title           String
  filePath        String?
  fileFormat      FileFormat?
  status          ReportStatus   @default(PENDING)
  generatedAt     DateTime       @default(now())
  sentAt          DateTime?
  recipientEmail  String?
  createdAt       DateTime       @default(now())

  @@index([type])
  @@index([period])
  @@index([status])
  @@index([generatedAt])
  @@map("reports")
}

// KPIs stockés
model KPI {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @unique
  value           Float
  unit            String?
  category        String?
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  @@index([category])
  @@map("kpis")
}

// Configuration du dashboard
model DashboardConfig {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @db.Uuid
  config      Json
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@map("dashboard_configs")
}