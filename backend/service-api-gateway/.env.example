# Port sur lequel l'API Gateway écoute
PORT=3010

# URL du service utilisateurs
USERS_SERVICE_URL=http://localhost:3011

USERS_SERVICE_PORT=3011

# URL du service conteneurs
CONTAINERS_SERVICE_URL=http://localhost:3012

CONTAINERS_SERVICE_PORT=3012


# URL du service de routes
ROUTES_SERVICE_URL=http://localhost:3013

ROUTES_SERVICE_PORT=3013


# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
NODE_ENV=development

# nombre de coeurs de CPU à utiliser pour le clustering
CLUSTER_WORKERS=2

JWT_SECRET=jwt-secret
JWT_EXPIRES_IN=1h