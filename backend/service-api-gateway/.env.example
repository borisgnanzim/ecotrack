# Port sur lequel l'API Gateway écoute
PORT=3010

# URL du service utilisateurs
USERS_SERVICE_URL=http://localhost:3011

USERS_SERVICE_PORT=3011

# URL du service conteneurs
CONTAINERS_SERVICE_URL=http://localhost:3012

CONTAINERS_SERVICE_PORT=3012


# URL du service de routes
ROUTES_SERVICE_URL=http://localhost:3013

ROUTES_SERVICE_PORT=3013

# URL du service d'analyses
ANALYTICS_SERVICE_URL=http://localhost:3014
ANALYTICS_SERVICE_PORT=3014


# Kafka Broker (pour les services en local avec Docker)
KAFKA_BROKERS=localhost:19092

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
NODE_ENV=development

# nombre de coeurs de CPU à utiliser pour le clustering
CLUSTER_WORKERS=2

JWT_SECRET=jwt-secret
JWT_EXPIRES_IN=1h

# CORS - Origines autorisées (séparées par des virgules)
# Si non défini, utilise les defaults du développement local
# Format: http://localhost:3000,http://localhost:5173,https://example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173