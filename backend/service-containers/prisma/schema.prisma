generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Zone - Zone géographique de collecte
model Zone {
  id          String      @id                   // ex: "ZB12", "ZONE-NORD"
  name        String      @unique
  city        String
  district    String?
  description String?
  isActive    Boolean     @default(true)
  polygon     Json?                              // GeoJSON Polygon / MultiPolygon
  latitude    Float?                             // Coordonnée centroïde
  longitude   Float?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  containers  Container[]

  @@map("zones")
}

// Container - Conteneurs intelligents avec capteurs IoT
model Container {
  id            String        @id @default(uuid()) @db.Uuid
  type          String        // Type de déchet (recyclage, organique, etc)
  status        String?       // Statut du conteneur (active, maintenance, etc)
  zoneId        String?       // FK vers Zone.id (null = non assigné)
  zone          Zone?         @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  capacity      Int?          // Capacité maximale en litres
  code          Int           @unique // Code unique du conteneur
  fillLevel     Int           @default(0) // Niveau de remplissage courant (0-100%)

  latitude      Float?        // Coordonnée GPS
  longitude     Float?        // Coordonnée GPS
  photoUrl      String?       // URL de la photo

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  fillHistory   FillHistory[]

  @@index([zoneId])
  @@index([status])
  @@index([code])
  @@map("containers")
}

// FillHistory - Historique des niveaux de remplissage
model FillHistory {
  id            String       @id @default(uuid()) @db.Uuid
  fillLevel     Int          // Niveau de remplissage (0-100%)
  recordedAt    DateTime     @default(now())

  containerId   String       @db.Uuid
  container     Container    @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
  @@index([recordedAt])
  @@map("fill_history")
}
