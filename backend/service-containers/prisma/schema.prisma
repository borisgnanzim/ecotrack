generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model conteneur {
  id_conteneur   String        @id @default(uuid()) @db.Uuid
  type_Dechet    String
  Statut         String?
  id_Zone        String
  capacite_i     Int?
  code_conteneur Int           @unique

  latitude       Float?
  longitude      Float?
  photo_url      String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  fillHistory    FillHistory[]
}

model FillHistory {
  id             String       @id @default(uuid()) @db.Uuid
  niveau         Int
  recordedAt     DateTime     @default(now())

  conteneurId    String       @db.Uuid
  conteneur      conteneur   @relation(fields: [conteneurId], references: [id_conteneur], onDelete: Cascade)
}
