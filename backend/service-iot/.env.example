# ─────────────────────────────────────────────────────────────────────────────
#  Service IoT — EcoTrack
#  Copiez ce fichier en .env et ajustez les valeurs à votre environnement.
#  Ne committez JAMAIS le fichier .env (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────────────────────


# ── Serveur HTTP ──────────────────────────────────────────────────────────────

# Port d'écoute du service REST
# Par défaut : 3015
PORT=3015


# ── Base de données PostgreSQL ────────────────────────────────────────────────

# URL de connexion Prisma
# Format : postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
# Port standard PostgreSQL : 5432
# EcoTrack utilise le port 5433 pour éviter les conflits avec d'autres instances
DATABASE_URL="postgresql://postgres:password@localhost:5433/iot_db?schema=public"


# ── Broker MQTT (Mosquitto) ───────────────────────────────────────────────────

# URL du broker MQTT auquel le service s'abonne
# Protocole : mqtt:// (non chiffré) ou mqtts:// (TLS)
# Le service écoute le topic : containers/+/data
MQTT_URL="mqtt://localhost:1883"


# ── Apache Kafka ──────────────────────────────────────────────────────────────

# Adresse(s) du ou des brokers Kafka, séparées par des virgules
# Docker Compose EcoTrack expose Kafka sur le port 19092
# Plusieurs brokers : KAFKA_BROKERS=host1:9092,host2:9092
KAFKA_BROKERS=localhost:19092
