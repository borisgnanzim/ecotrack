datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AlertType {
  CRITICAL_FILL
  SENSOR_OFFLINE
  TEMPERATURE_ANOMALY
  HUMIDITY_ANOMALY
  MAINTENANCE
}

// Measurement - Données brutes des capteurs
model Measurement {
  id            String    @id @default(uuid()) @db.Uuid
  containerId   String    @db.Uuid
  fillLevel     Int       // Niveau de remplissage (0-100)
  temperature   Float?    // Température en °C
  humidity      Float?    // Humidité relative (%)
  createdAt     DateTime  @default(now())
  anomaly       Boolean   @default(false)

  @@index([containerId])
  @@index([createdAt])
  @@map("measurements")
}

// SensorStatus - Dernier statut connu d'un capteur
model SensorStatus {
  id              String    @id @default(uuid()) @db.Uuid
  containerId     String    @db.Uuid @unique
  lastFillLevel   Int?
  lastTemperature Float?
  lastHumidity    Float?
  lastSeen        DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([containerId])
  @@map("sensor_statuses")
}

// Alert - Alertes générées
model Alert {
  id            String    @id @default(uuid()) @db.Uuid
  containerId   String    @db.Uuid
  type          AlertType
  message       String
  createdAt     DateTime  @default(now())
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?

  @@index([containerId])
  @@index([type])
  @@index([resolved])
  @@index([createdAt])
  @@map("alerts")
}
