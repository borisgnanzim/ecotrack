datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AlertType {
  CRITICAL_FILL
  SENSOR_OFFLINE
  TEMPERATURE_ANOMALY
  HUMIDITY_ANOMALY
  MAINTENANCE
}

model Measurement {
  id          String   @id @default(uuid()) @db.Uuid
  containerId String   @db.Uuid
  fillLevel   Int
  temperature Float?
  humidity    Float?
  anomaly     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([containerId])
  @@index([createdAt])
  @@map("measurements")
}

model SensorStatus {
  id              String    @id @default(uuid()) @db.Uuid
  containerId     String    @db.Uuid @unique
  lastFillLevel   Int?
  lastTemperature Float?
  lastHumidity    Float?
  lastSeen        DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([containerId])
  @@map("sensor_statuses")
}

model Alert {
  id          String    @id @default(uuid()) @db.Uuid
  containerId String    @db.Uuid
  type        AlertType
  message     String
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([containerId])
  @@index([type])
  @@index([resolved])
  @@index([createdAt])
  @@map("alerts")
}
