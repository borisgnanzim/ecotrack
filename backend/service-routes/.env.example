# ──────────────────────────────────────────────
# SERVICE ROUTES — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────

# ── Base de données ────────────────────────────
DATABASE_URL="postgresql://postgres:motdepasse@localhost:5433/routes_db?schema=public"
USERNAME=postgres
BASE=routes_db

# ── Serveur ────────────────────────────────────
PORT=3013
NODE_ENV=development

# ── Authentification JWT ───────────────────────
# Doit être identique au secret utilisé dans service-api-gateway
JWT_SECRET=jwt-secret

# ── Kafka ──────────────────────────────────────
# Local sans Docker : localhost:19092
# Avec Docker Compose : kafka:9092
KAFKA_BROKERS=localhost:19092

# ── CORS ───────────────────────────────────────
# Origines autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ── Email (SMTP) ───────────────────────────────
# Requis pour POST /routes/:id/send (envoi feuille de route PDF)
# Gmail : activer "Mots de passe d'application" dans les paramètres de sécurité
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@gmail.com
SMTP_PASS=votre-app-password
