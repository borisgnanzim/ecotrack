generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RouteStatus {
  planned
  in_progress
  completed
  cancelled
}

// User - Reference to service-users (UUID)
model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  username      String
  name          String?
  points        Int       @default(0)
  address       String?
  avatar        String?
  badges        String[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  routes        Route[]   @relation("UserRoutes")

  @@map("users")
}

// Container - Reference to service-containers (UUID)
model Container {
  id            String    @id @default(uuid()) @db.Uuid
  type          String    // type_Dechet
  status        String?   // Statut
  zoneId        String    // id_Zone
  capacity      Int?      // capacite_i
  code          Int       @unique

  latitude      Float?
  longitude     Float?
  photoUrl      String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  fillLevel     Int?      @default(0)

  routeSteps    RouteStep[]

  @@map("containers")
}

// Route - Routes de collecte
model Route {
  id              String       @id @default(uuid()) @db.Uuid
  date            DateTime
  startTime       DateTime?
  endTime         DateTime?
  agentId         String?      @db.Uuid
  agent           User?        @relation("UserRoutes", fields: [agentId], references: [id], onDelete: SetNull)
  status          RouteStatus  @default(planned)
  containerIds    String[]     @default([])  // List of container IDs
  totalDistance   Float?
  estimatedTime   Int?         // en minutes

  steps           RouteStep[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([date])
  @@map("routes")
}

// RouteStep - Étapes dans une tournée
model RouteStep {
  id                        String    @id @default(uuid()) @db.Uuid
  routeId                   String    @db.Uuid
  route                     Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  containerId               String    @db.Uuid
  container                 Container @relation(fields: [containerId], references: [id], onDelete: Restrict)
  
  stepOrder                 Int
  distanceFromPrevious      Float?    // en km
  estimatedTimeFromPrevious Int?      // en minutes

  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([routeId, stepOrder])
  @@index([routeId])
  @@index([containerId])
  @@map("route_steps")
}
