# .env.example - Exemple de variables d'environnement pour ecotrack-service-users
# Copie ce fichier vers `.env` et adapte les valeurs pour ton environnement

# Port sur lequel l'application écoute
PORT=3011

# Connexion PostgreSQL (format: postgres://user:password@host:port/dbname)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecotrack_service_users

# Mode d'envoi des notifications: 'local' (écrire en base) ou 'http' (POST vers un service externe)
NOTIFICATION_MODE=local
# URL du service de notifications lorsque NOTIFICATION_MODE=http (ex: http://notifications-service:3000)
NOTIFICATION_SERVICE_URL=http://notifications-service:3000

# Kafka Broker (pour les services en local avec Docker)
KAFKA_BROKERS=localhost:19092


# Secret JWT (change le en production)
JWT_SECRET=jwt-secret
JWT_EXPIRES_IN=1h

# CORS - Origines autorisées (séparées par des virgules)
# Si non défini, utilise les defaults du développement local
# Format: http://localhost:3000,http://localhost:5173,https://example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:3010,http://127.0.0.1:5174




# Variables Mongo (optionnel, seulement si tu utilises encore Mongo pour la migration)
# MONGO_URI=mongodb://localhost:27017/ecotrack_service_users
# DB_NAME=ecotrack_service_users
